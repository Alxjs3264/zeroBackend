crita en la nota anteriormente mencionada por la Dirección General del Registro Público de la Abogacía se realizó la actualización automática (ejecución de script) de 2201 datos de personas, 339 registros de abogados fallecidos y 502 registros de personas con complemento visible. los mismos son descritos en la Nota Interna MJTI-DGAA-ATIC-91/2021 adjuntada en la presente.</p><p>En cuanto a la integridad de la información se realizó el backup de la base de datos antes y después de la actualización de los registros los mismos son adjuntados a la presente en CD, así como los scripts ejecutados.</p>"},"active":false,"visible":true,"disabled":false,"readonly":false,"required":false,"ariaLabel":null,"typeInput":"text","customClass":null,"placeholder":null,"validations":[],"autocomplete":null,"customStyles":null,"designColumn":"col-12","ariaLabelledBy":null},{"uid":"574bc53c-d707-4737-acc3-c8dd7734dbea","edit":true,"name":"title3","type":"title","label":"Sin otro particular me despedido, con las consideraciones más distinguidas.","value":{"uid":"574bc53c-d707-4737-acc3-c8dd7734dbea","name":"title3","type":"title","valores":""},"active":false,"visible":true,"disabled":false,"readonly":false,"required":false,"ariaLabel":null,"typeInput":"normal","customClass":null,"placeholder":null,"validations":[],"autocomplete":null,"customStyles":null,"designColumn":"col-12","ariaLabelledBy":null}],"configuracionPagina":{"margenDerecho":3,"tamanioPagina":{"alto":"27.94","ancho":"21.59","nombre":"CARTA"},"margenInferior":3,"margenSuperior":3,"margenIzquierdo":4},"permiteCiteDiferente":false,"permite_confidencial":false,"habilitarPalabrasClave":false,"configuracionExportacion":[]},"plantillaValor":[{"uid":"2b66563b-2ec1-419a-9c00-af14f231e2b2","name":"derivacionNaN","type":"derivacion","valores":{"de":[{"id":"fae19b02-e9fb-44cd-be06-21a0e6df7f9c","cargo":{"id":"a9df11b6-e917-42ba-bd42-387f4d64a9fe","nivel":"PRIMERA","estado":"ACTIVO","unidad":{"id":"a8f530a0-8d4c-40a9-864a-b360b2975eab","si