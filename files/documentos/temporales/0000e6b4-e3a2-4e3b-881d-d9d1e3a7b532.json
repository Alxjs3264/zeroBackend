aFuncional"},{"label":"Dependendencia formulario","value":"idDependenciaFormulario"},{"label":"Dependendencia POAI","value":"idDependenciaPoai"},{"label":"Aprueba viaje","value":"idApruebaViaje"},{"label":"Elabora Memorandum Viaje","value":"idElaboraMemorandumViaje"}],"modificarVisibilidadPdf":true},{"uid":"bf09a588-6f9d-408d-a4b0-854b22479448","edit":true,"name":"contenido","type":"editor","label":"","value":{"uid":"bf09a588-6f9d-408d-a4b0-854b22479448","name":"contenido","type":"editor","valores":"<div style=\"text-align: justify;\"><p>La Paz, 11 de marzo de 2024</p>\n\n<p><b>&nbsp;</b></p>\n\n<div>Señor:<br> German Daniel Jiménez Terán<br><b>DIRECTOR EJECUTIVO<br></b><b>AGENCIA NACIONAL DE HIDROCARBUROS<br></b><u>Presente</u>.-&nbsp; </div>\n\n\n\n\n\n\n\n\n\n<p>&nbsp;</p>\n\n<p style=\"text-align: right;\"><b>REF.:</b> <b><u>REMISIÓN DE CONVENIO INTERINSTITUCIONAL</u></b><b><u>&nbsp; </u></b></p>\n\n<p>&nbsp;</p>\n\n<p>De mi\nconsideración:</p><p>A\ntiempo de saludarle cordialmente, me dirijo a su Autoridad, en atención a la\nnota ANH 06517 DJ 0177/2024 por la cual nos remite la “Adenda al Convenio de\nCooperación Interinstitucional suscrito entre la Agencia Nacional de\nHidrocarburos el Ministerio de Justicia Transparencia Institucional y el\nViceministerio de Transparencia Institucional y Lucha contra la Corrupción”,\nmismo &nbsp;que tiene por objeto proporcionar\nacceso al MJTI a datos gestionados por el Sistema Boliviano de\nAutoidentificación y Control de Combustibles (B-SISA) de la ANH.</p><p>Al\nrespecto, habiéndose formalizado el Convenio de Cooperación citado, tengo a\nbien remitir en dos (2) ejemplares originales para su implementación\ncorrespondiente.</p><p>Sin\notro particular, hago propicia la ocasión para expresar a usted las\nconsideraciones más distinguidas.</p><p>Atentamente.</p>\n\n<p>&nbsp;</p>\n\n<p>&nbsp;</p>\n\n<p>&nbsp;</p>\n\n<p>&nbsp;</p><p><br></p><p><br></p>\n\n<div><i><font size=\"1\">MFCC/amav/jggv</font></i><br><i><font size=\"1\">C.c.//Arch.</font></i></div><div><i><font size=\"1\">Adj. Lo indicado.<br></font></i></div>\n\n\n\n\n\n\n\n</div>"},"active":false,"visible":true,"disabled":false,"readonly":false,"required":false,"ariaLabel":null,"typeInput":"text","customClass":null,"placeholder":null,"validations":[],"autocomplete":null,"customStyles":null,"defaultValue":"","designColumn":"col-12","ariaLabelledBy":null}],"configuracionPagina":{"margenDerecho":3,"tamanioPagina":{"alto":"27.94","ancho":"21.59","nombre":"CARTA"},"margenInferior":3,"margenSuperior":3,"margenIzquierdo":4},"permite_confidencial":false,"habilitarPalabrasClave":false,"configuracionExportacion":[]},"plantillaValor":[{"uid":"b82d7e8e-f5e9-4cb1-ba65-359a84b8b262","name":"derivacionNaN","type":"derivacion","valores":{"de":[{"id":"46e8deaa-b356-42dd-af36-04ca526bee4a","cargo":{"id":"c404327e-cd83-4824-8837-0ac49bc67038","nivel":"TERCERA","estado":"ACTIVO","unidad":{"id":"14cd84de-c4e3-4734-8fb6-107ecfbca71d","sigla":"DGAJ","estado":"ACTIVO","nombreArea":"DIRECCIÓN GENERAL DE ASUNTOS JURIDICOS"},"nroItem":"38","descripcion":"PROFESIONAL ABOGADO (A)","idTipoPuesto":"760f0dd0-59ef-4c6c-bdf5-1277992054b1","idUnidadOrganizacional":"14cd84de-c4e3-4734-8fb6-107ecfbca71d"},"estado":"ACTIVO","idCargo":"c404327e-cd83-4824-8837-0ac49bc67038","usuario":{"id":"78e04a48-eb04-46ae-8ebd-48c2b783e5a3","foto":null,"cargo":"PROFESIONAL ABOGADO (A)","estado":"ACTIVO","celular":null,"entidad":{"id":"745034da-06cb-4d98-8fee-4c982adfbb22","sigla":"MJTI","codigo":null,"nombre":"MINISTERIO DE JUSTICIA "},"idCargo":"c404327e-cd83-4824-8837-0ac49bc67038","nombres":"JAIME GONZALO","usuario":"5740723","telefono":null,"idEntidad":"745034da-06cb-4d98-8fee-4c982adfbb22","complemento":null,"tipoDocumento":"CI","primerApellido":"GONGORA","fechaNacimiento":"1983-12-26","numeroDocumento":"5740723","segundoApellido":"VELIZ","correoElectronico":"james107@gmail.com"},"idUsuario":"78e04a48-eb04-46ae-8ebd-48c2b783e5a3","visiblePdf":true,"seleccionado":true,"seleccio