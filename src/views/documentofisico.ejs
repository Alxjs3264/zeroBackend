<!DOCTYPE html>
<html lang="en">
    
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
  <meta http-equiv="X-UA-Compatible" content="ie=edge">
  <title>PDF</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css" integrity="sha384-BVYiiSIFeK1dGmJRAkycuHAHRg32OmUcww7on3RYdg4Va+PmSTsz/K68vbdEjh4u" crossorigin="anonymous">
  <style>
    table, th, td {
  border: 1px solid black;
}
        body {
            font-family: Poppins,-apple-system,Helvetica Neue,Helvetica,Arial,sans-serif;
            font-size: 13pt;
            line-height: 1.5;
            margin-left: 4;
            margin-right:3;
        }

        .text-justify {
          text-align: justify !important;
        }

        hr.salto{
            page-break-before: always;
        }
        .form-check {
            border: 1px solid #e4e6ef;
            display: inline-block;
            width: 100%;
            margin-bottom: 10px;
            padding-left: 10px;
            padding-right: 10px;
            border-radius: 4px 4px 0 0;
            height: 100%!important;
        }
        .form-check-inline {
            display: inline-block;
            align-items: center!important;
            height: 40px;
            padding-top: 9px;
            padding-bottom: 9px;
            height: 100%!important;
        }
        .center {
            display: inline-block;
            vertical-align: middle;
            height: 40px;
        }
        .q-radio__bg {
            fill: #023859;
            font-size: 22px;
            width: 1em;
            height: 1em;
        }
        .q-radio__bg_not_selected {
            font-size: 22px;
            width: 1em;
            height: 1em;
            fill: rgba(0, 0, 0, 0.54);
        }
        .q-checkbox__bg {
            fill: #023859;
            font-size: 22px;
            width: 1em;
            height: 1em;
        }
        .q-checkbox__bg_not_selected {
            font-size: 22px;
            width: 1em;
            height: 1em;
            fill: rgba(0, 0, 0, 0.54);
        }
        .subtitle, .title {
            font-weight: bold;
            margin: 0 0 10px;
        }
        .title {
            font-size: 29px;
            line-height: 35px;
            font-weight: bold;
        }
        .subtitle {
            font-size: 23px;
            font-weight: bold;
            line-height: 29px;
        }
        .text-bold {
            font-weight: 700;
        }
        .text-h4 {
            font-size: 20pt;
            font-weight: 700;
            letter-spacing: .009em;
        }
        .q-separator--horizontal {
            display: block;
            height: 2px;
        }
        .q-separator {
            background: black;
            border: 0;
            flex-shrink: 0;
            margin-bottom: 10px;
            margin-top: 10px;
            transition: background .3s,opacity .3s;
        }
        .text-label{
            font-weight: 600;
            font-size: 12px;
        }
        .cargo{
            margin-bottom: 0px;
        }
        .derivacion{
            margin-bottom: 10px;
        }
        ul { padding: 0; margin: 0; }
        .q-li {
            box-sizing: border-box;
            width: 100%;
            padding-top: 10px;
            padding-bottom: 10px;
        }
        table { page-break-inside:auto; width: 100%; height: 100%; }
        tbody tr { page-break-inside:avoid !important; page-break-after:auto !important }
        thead { display:table-header-group }
        tfoot { display:table-footer-group }
        .text-oculto{
            display: none;
        }
        .enlace{
            padding-bottom: 1.5rem;
        }
        .enlace .caption{
            overflow: hidden;
            text-overflow: ellipsis;
            display: -webkit-box;
            -webkit-box-orient: vertical;
            line-clamp: 1;
            -webkit-line-clamp: 1;
        }
    .page_break {
        page-break-before: always;
      }
  </style>
</head>
<body>
    <div>
        <table>
            <%- include('components/derivacionfisica.ejs', { datos: datos }) %>
            <tbody>
                <% for (var i = 0; i < 3; i++) {%>
                    <%- include('components/hojaderuta.ejs') %>
                <%}%>
            </tbody>
        </table>
        <br>
        <table class="page_break">
            <tbody>
                <% for (var i = 0; i < 4; i++) {%>
                    <%- include('components/hojaderuta.ejs') %>
                <%}%>
            </tbody>
        </table>
    </div>
</body>
</html>
