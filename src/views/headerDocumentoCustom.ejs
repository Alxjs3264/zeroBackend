<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
  <meta http-equiv="X-UA-Compatible" content="ie=edge">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css" integrity="sha384-BVYiiSIFeK1dGmJRAkycuHAHRg32OmUcww7on3RYdg4Va+PmSTsz/K68vbdEjh4u" crossorigin="anonymous">
  <style>
       body {
            font-family: Poppins,-apple-system,Helvetica Neue,Helvetica,Arial,sans-serif;
            font-size: 10pt;
        }
        .correlativo{
            padding-top: 0.5cm;
        }
        .background {
            position: fixed;
            top: 0;
            right: 0;
            width: 100%;
            height: 100%;
            padding-top: auto;
            z-index: -3000;
            opacity: 0.85;
            text-align: center;
        }
        .background img {
            margin: 200px auto;
            /* margin-top: 200px; */
        }
  </style>
</head>


<body>
    <div class="row">
        <div class="col-xs-6">
            <!--
            <img width="430" src="https://test.rpc.justicia.gob.bo/_nuxt/img/min_logo_2021_horizontal.cd3d135.png" />
            -->
              <%- contenidoHeader %>
         </div>
        <div class="col-xs-6 text-right correlativo">
           <p>
               <% if (documento?.flujoDocumental?.codigoFlujo) { %> 
                Hoja de Ruta : <%= documento?.flujoDocumental?.codigoFlujo %><br/>
              <% } if (documento?.cite) { %> 
                Cite : <%= documento?.cite %><br/>
                Fecha Emision : <%= documento?.fechaDocumento %>             
               <% } else { 
                   let date = new Date(); %>
                   Fecha Emision : <%= `${date.getDate()}-${date.getMonth() + 1}-${date.getFullYear()} ${date.getHours()}:${date.getMinutes()}:${date.getSeconds()}` %>
               <% } %>
           </p>
        </div>
        <div class="col-xs-5 text-right">
        </div>
    </div>
    <% if (['OBSERVADO', 'CANCELADO','INVALIDO'].includes(documento?.estado)) { %> 
        <div class="background" align="center">
            <img src="<%= `data:image/png;base64,${waterDraft}`%>">
        </div>
    <% } %>
</body>

</html>
