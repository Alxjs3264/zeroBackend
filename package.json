{
  "name": "backend-base",
  "version": "1.0.0",
  "description": "Backend base",
  "main": "src/application/index.js",
  "scripts": {
    "db": "npm run setup && npm run seeders",
    "start": "OPENSSL_CONF=/etc/ssl/ node src/application/server",
    "start:dev": "nodemon src/application/server --ignore 'files/*'",
    "dev": "OPENSSL_CONF=/etc/ssl/ nodemon src/application/server",
    "dev:win": "nodemon src/application/server.js",
    "dev:debug": "DEBUG=app:* OPENSSL_CONF=/etc/ssl/ nodemon src/application/server",
    "dev:debugw": "set DEBUG=app:* && nodemon src/application/server",
    "secure": "NODE_ENV=secure nodemon src/application/server",
    "test": "NODE_ENV=test npm run setup && NODE_ENV=test npm run seeders && npm run test-db && npm run test-domain",
    "test-db": "NODE_ENV=test ava src/infrastructure/tests/ --verbose",
    "test-domain": "NODE_ENV=test ava src/domain/tests/ --verbose",
    "test-common": "NODE_ENV=test ava src/common/tests/ --verbose",
    "setup": "node src/infrastructure/setup.js",
    "seeders": "sequelize db:seed:all --debug  --seeders-path src/infrastructure/seeders --config src/infrastructure/lib/config-seeders.js",
    "seeders-update": "NODE_ENV=production sequelize db:seed:all --seeders-path src/infrastructure/seeders/update --config src/lib/config-seeders.js",
    "seeders-prod": "NODE_ENV=production npm run seeders",
    "cron": "node cronjob/test",
    "lint": "semistandard",
    "migrations": "sequelize db:migrate --migrations-path src/infrastructure/migrations --config src/infrastructure/lib/config-seeders.js",
    "pdf:hash": "node src/common/lib/scripts/archivosPdf.js",
    "agregarRemitente": "node src/domain/scripts/agregarRemitenteFisicos.js",
    "actualizar:estructura": "node src/domain/scripts/actualizacionEstructura.js",
    "actualizar:final": "node src/domain/scripts/actualizacionFinal.js",
    "users:reset-password": "node src/domain/scripts/setDefaultPassword.js",
    "files:backup": "node src/domain/scripts/backupFiles.js"
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "keywords": [],
  "author": "Ivan Tancara Casilla <ivan.tancara.c@gmail.com>",
  "license": "",
  "dependencies": {
    "@severi/pdf-merger-js": "^3.1.2",
    "axios": "^0.21.1",
    "bcrypt": "^5.0.1",
    "body-parser": "^1.19.0",
    "canvas": "^3.2.0",
    "chalk": "^4.1.1",
    "cheerio": "^1.1.2",
    "cors": "^2.8.5",
    "csvtojson": "^2.0.10",
    "debug": "^4.3.3",
    "defaults": "^1.0.3",
    "docx": "^9.5.1",
    "dotenv": "^17.3.1",
    "ejs": "^3.1.6",
    "express": "^4.17.1",
    "express-fileupload": "^1.2.1",
    "form-data": "^4.0.0",
    "geoip-lite": "^1.4.2",
    "html-pdf": "^3.0.0",
    "html-to-docx": "^1.8.0",
    "inquirer": "^8.0.0",
    "intl": "^1.2.5",
    "intl-messageformat": "^9.6.11",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^8.5.1",
    "jsqr": "^1.4.0",
    "log4js": "^6.3.0",
    "mime-types": "^2.1.35",
    "minimist": "^1.2.5",
    "moment": "^2.29.1",
    "nodemailer": "^6.6.0",
    "nodemailer-smtp-transport": "^2.7.4",
    "openid-client": "^4.7.2",
    "pdf-lib": "^1.17.1",
    "pdf2pic": "^3.2.0",
    "pg": "^8.6.0",
    "pg-hstore": "^2.3.3",
    "pm2": "^6.0.14",
    "puppeteer": "^24.26.1",
    "qrcode": "^1.5.4",
    "sequelize": "^6.6.2",
    "sequelize-cli": "^6.2.0",
    "sha256": "^0.2.0",
    "socket.io": "^4.5.0",
    "uuid": "^8.3.2",
    "validate.js": "^0.13.1",
    "web-push": "^3.4.4",
    "wkhtmltopdf": "^0.4.0"
  },
  "devDependencies": {
    "ava": "^3.15.0",
    "eslint": "^7.25.0",
    "eslint-config-standard": "^16.0.2",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^5.1.0",
    "eslint-plugin-standard": "^5.0.0",
    "nodemon": "^2.0.7",
    "semistandard": "^16.0.0"
  }
}
